package client.game;

import client.GameClient;
import common.Protocol;

import javax.swing.SwingUtilities;

public class GameController {

    private static GameController instance;

    private final GameClient gameClient;
    private final ChatPanel chatPanel;
    private String roomId;

    public GameController(
            GameClient gameClient,
            ChatPanel chatPanel,
            String roomId
    ) {
        this.gameClient = gameClient;
        this.chatPanel = chatPanel;
        this.roomId = roomId;

        // GameClientの静的受信処理から参照できるようにする
        instance = this;

        // 送信ボタンとEnterキーの処理を登録
        chatPanel.setSendAction(e -> sendChat());
    }

    // 現在操作している部屋を変更する
    public void setRoomId(String roomId) {
        this.roomId = roomId;
    }

    // サーバーへゲーム開始を要求する
    public void requestGameStart() {
        if (roomId == null || roomId.trim().isEmpty()) {
            chatPanel.showSystemMessage(
                    "部屋に参加してからゲームを開始してください"
            );
            return;
        }

        gameClient.sendMessage(
                Protocol.GAME_START + ":" + roomId
        );
    }

    // 入力されたチャット・回答をサーバーへ送る
    private void sendChat() {
        String text = chatPanel.getInputText();

        if (text == null || text.trim().isEmpty()) {
            return;
        }

        if (roomId == null || roomId.trim().isEmpty()) {
            chatPanel.showSystemMessage(
                    "部屋に参加していません"
            );
            return;
        }

        gameClient.sendMessage(
                Protocol.CHAT_SUBMIT
                        + ":"
                        + roomId
                        + ","
                        + text.trim()
        );

        chatPanel.clearInput();
    }

    /*
     * GameClientがサーバーから担当Cのコマンドを受信したときに
     * 呼び出すメソッド。
     */
    public static void onGameUpdate(
            String command,
            String data
    ) {
        if (instance == null) {
            System.out.println(
                    "GameControllerが初期化されていません: "
                            + command
                            + ":"
                            + data
            );
            return;
        }

        /*
         * GameClientの受信処理はバックグラウンドスレッドで動くため、
         * Swingの画面更新はイベントディスパッチスレッドで実行する。
         */
        SwingUtilities.invokeLater(
                () -> instance.handleGameUpdate(command, data)
        );
    }

    private void handleGameUpdate(
            String command,
            String data
    ) {
        switch (command) {
            case Protocol.GAME_ROUND_START:
                handleRoundStart(data);
                break;

            case Protocol.CHAT_BROADCAST:
                handleChatBroadcast(data);
                break;

            case Protocol.GAME_JUDGE_RESULT:
                handleJudgeResult(data);
                break;

            case Protocol.GAME_SCORE_UPDATE:
                chatPanel.updateScores(data);
                break;

            case Protocol.GAME_TIME_UPDATE:
                handleTimeUpdate(data);
                break;

            case Protocol.GAME_ROUND_END:
                chatPanel.showRoundEnd(data);
                break;

            case Protocol.GAME_END:
                chatPanel.showGameEnd(data);
                break;

            default:
                System.out.println(
                        "未対応のゲームコマンド: "
                                + command
                );
                break;
        }
    }

    private void handleRoundStart(String data) {
        String[] parts = data.split(",", 2);
        String role = parts.length > 0
                ? parts[0].trim()
                : "";

        if ("DRAWER".equals(role)) {
            String theme = parts.length > 1
                    ? parts[1]
                    : "";

            chatPanel.showDrawerRole(theme);
        } else if ("GUESSER".equals(role)) {
            String drawerName = parts.length > 1
                    ? parts[1]
                    : "";

            chatPanel.showGuesserRole(drawerName);
        } else {
            chatPanel.showSystemMessage(
                    "不正な役割情報を受信しました"
            );
        }
    }

    private void handleChatBroadcast(String data) {
        String[] parts = data.split(",", 2);

        String userName = parts.length > 0
                ? parts[0]
                : "不明";

        String message = parts.length > 1
                ? parts[1]
                : "";

        chatPanel.appendChat(userName, message);
    }

    private void handleJudgeResult(String data) {
        String[] parts = data.split(",", 3);

        String userName = parts.length > 0
                ? parts[0]
                : "不明";

        String result = parts.length > 1
                ? parts[1]
                : "";

        String answer = parts.length > 2
                ? parts[2]
                : "";

        switch (result) {
            case "CORRECT":
                chatPanel.showSystemMessage(
                        userName + "さんが正解しました！"
                );
                break;

            case "WRONG":
                // 発言自体はCHAT_BROADCASTで表示される
                break;

            case "ALREADY_CORRECT":
                chatPanel.showSystemMessage(
                        userName
                                + "さんはすでに正解しています"
                );
                break;

            default:
                chatPanel.showSystemMessage(
                        "判定結果を認識できません: "
                                + result
                                + " "
                                + answer
                );
                break;
        }
    }

    private void handleTimeUpdate(String data) {
        try {
            int remainingSeconds =
                    Integer.parseInt(data.trim());

            chatPanel.updateTime(remainingSeconds);
        } catch (NumberFormatException e) {
            chatPanel.showSystemMessage(
                    "残り時間の形式が不正です: " + data
            );
        }
    }
}
